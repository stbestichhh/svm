#!/usr/bin/env bash

set -e

MODE=""
HAS_MOUNT=false
PERSIST_NAME=""
TARGET_NAME=""

# -------------------------
# Parse arguments
# -------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
    node|ubuntu|debian)
      MODE="$1"
      shift
      ;;

    -m|--mount)
      HAS_MOUNT=true
      shift
      ;;

    -p|--persist)
      PERSIST_NAME="$2"
      shift 2
      ;;

    ls|list)
      MODE="list"
      shift
      ;;

    open)
      MODE="open"
      TARGET_NAME="$2"
      shift 2
      ;;

    rm|remove)
      MODE="remove"
      TARGET_NAME="$2"
      shift 2
      ;;

    help|-h|--help|"")
      MODE="help"
      shift
      ;;

    *)
      echo "Unknown argument: $1"
      exit 1
      ;;
  esac
done

# -------------------------
# Run container
# -------------------------
run_container() {
  local IMAGE="$1"
  local WORKDIR="$2"

  if [[ -n "$PERSIST_NAME" ]]; then

    if ! docker ps -a --format '{{.Names}}' | grep -q "^$PERSIST_NAME$"; then

      if $HAS_MOUNT; then
        docker create -it \
          --name "$PERSIST_NAME" \
          -v "$PWD":"$WORKDIR" \
          -w "$WORKDIR" \
          "$IMAGE" \
          bash
      else
        docker create -it \
          --name "$PERSIST_NAME" \
          "$IMAGE" \
          bash
      fi
    fi

    docker start -ai "$PERSIST_NAME"
    return
  fi

  if $HAS_MOUNT; then
    docker run -it --rm \
      -v "$PWD":"$WORKDIR" \
      -w "$WORKDIR" \
      "$IMAGE" \
      bash
  else
    docker run -it --rm "$IMAGE" bash
  fi
}

run_node() {
  run_container "node:22" "/app"
}

run_ubuntu() {
  run_container "ubuntu" "/workspace"
}

run_debian() {
  run_container "debian:latest" "/workspace"
}

# -------------------------
# Commands
# -------------------------

cmd_ls() {
  echo "Active svm environments:"
  docker ps -a --format "table {{.Names}}\t{{.Status}}\t{{.Image}}" | grep -E "node|ubuntu|debian" || true
}

cmd_open() {
  if [[ -z "$TARGET_NAME" ]]; then
    echo "Usage: svm open <name>"
    exit 1
  fi

  if ! docker ps -a --format '{{.Names}}' | grep -q "^$TARGET_NAME$"; then
    echo "Container '$TARGET_NAME' not found"
    exit 1
  fi

  docker start -ai "$TARGET_NAME"
}

cmd_remove() {
  if [[ -z "$TARGET_NAME" ]]; then
    echo "Usage: svm remove <name>"
    exit 1
  fi

  if docker ps -a --format '{{.Names}}' | grep -q "^$TARGET_NAME$"; then
    docker rm -f "$TARGET_NAME"
    echo "Removed $TARGET_NAME"
  else
    echo "Container '$TARGET_NAME' not found"
  fi
}

# -------------------------
# Help
# -------------------------
show_help() {
  echo "svm - simple Docker sandbox manager"
  echo ""
  echo "Usage:"
  echo "  svm <node|ubuntu> [options]"
  echo "  svm ls"
  echo "  svm open <name>"
  echo "  svm remove <name>"
  echo ""
  echo "Commands:"
  echo "  node              Node.js environment (node:22)"
  echo "  ubuntu            Ubuntu environment"
  echo "  debian            Debian environment (debian:latest)"
  echo "  ls                List environments"
  echo "  open <name>       Attach to environment"
  echo "  remove <name>     Delete environment"
  echo ""
  echo "Options:"
  echo "  -m, --mount           Mount current directory"
  echo "  -p, --persist <name>  Persistent container"
  echo ""
  echo "Examples:"
  echo "  svm node -p api"
  echo "  svm ls"
  echo "  svm open api"
  echo "  svm remove api"
}

# -------------------------
# Router
# -------------------------
case "$MODE" in
  node)
    run_node
    ;;
  ubuntu)
    run_ubuntu
    ;;
  debian)
    run_debian
    ;;
  list)
    cmd_ls
    ;;
  open)
    cmd_open
    ;;
  remove)
    cmd_remove
    ;;
  help)
    show_help
    ;;
  *)
    show_help
    exit 1
    ;;
esac